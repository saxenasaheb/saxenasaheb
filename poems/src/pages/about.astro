---
import BaseLayout from '../layouts/BaseLayout.astro';
import { POET } from '../lib/poems';
---
<BaseLayout title={`परिचय — ${POET.name}`} description={`${POET.name} का परिचय।`}>
  <section class="about wrap">
    <h1 lang="hi">परिचय</h1>

    <div class="reading">
      <img
        class="about-portrait"
        src="/portrait.jpg"
        width="200"
        height="240"
        alt="डॉ. प्रणव गौतम"
      />

      <div class="about-body" lang="hi">
        <p>
          डॉ. प्रणव गौतम पिछले दो दशकों से अधिक समय से चिकित्सा के क्षेत्र में हैं।
          बरेली में जन्मे और पले-बढ़े, यही शहर आज भी उनकी बहुत-सी रचनाओं में बसा
          हुआ है।
        </p>
        <p>
          उनके लिए चिकित्सा और कविता कभी एक-दूसरे से दूर नहीं रहीं — दोनों ही इंसान
          को, उसके मन को, और जीवन के छोटे-छोटे एहसासों को ध्यान से देखने का तरीक़ा
          हैं। उनकी कविताएँ और ग़ज़लें प्रेम, सौंदर्य और भारत के इर्द-गिर्द घूमती
          हैं — वे विषय जिनकी ओर वे बार-बार लौटते हैं।
        </p>
        <p>
          वे बरेली में अपनी पत्नी, जो अंग्रेज़ी की प्राध्यापिका हैं, और अपने दो
          बच्चों — एक बेटे और एक बेटी — के साथ रहते हैं।
        </p>
        <p class="about-affil">
          यहाँ संकलित ये रचनाएँ उनके वर्षों के अनुभव, प्रेम और जीवन के प्रति उनकी
          दृष्टि का प्रतिबिंब हैं।
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
