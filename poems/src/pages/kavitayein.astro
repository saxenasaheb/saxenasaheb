---
import BaseLayout from '../layouts/BaseLayout.astro';
import PoemList from '../components/PoemList.astro';
import { getSortedPoems } from '../lib/poems';

const poems = await getSortedPoems('kavita');
---
<BaseLayout
  title="कविताएँ — डॉ. प्रणव गौतम"
  description="डॉ. प्रणव गौतम की कविताएँ।"
>
  <div class="wrap">
    <div class="page-head">
      <h1 lang="hi">कविताएँ</h1>
      <p lang="hi">{poems.length} रचनाएँ</p>
      <hr class="rule" />
    </div>
    <PoemList poems={poems} />
  </div>
</BaseLayout>
