# Mapbox — client (public scoped) token, used by the map UI in the browser.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_public_scoped_token

# Mapbox — server token, used by the geocoding stage (A6). Keep secret.
MAPBOX_TOKEN=sk.your_server_token

# A4 MCA download source. The MCA portal URL format has changed before; if the
# default 403s or returns the wrong format, point this at a working mirror or a
# locally-downloaded file path (file:///abs/path/to/karnataka.xlsx also works).
MCA_KARNATAKA_URL=https://reports.mca.gov.in/MinistryV2/master+details.html

# A2 YC directory is powered by Algolia. These public search keys rotate; grab
# current values from the ycombinator.com/companies network tab if A2 fails.
YC_ALGOLIA_APP_ID=45BWZJ1SGC
YC_ALGOLIA_API_KEY=
YC_ALGOLIA_INDEX=YCCompany_production

# Optional: Brandfetch API key, a paid fallback for logos (A7). Leave blank to
# rely on Google favicon + generated monogram only.
BRANDFETCH_API_KEY=
